<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="start|top"
    android:gravity="start|top"
    android:id="@+id/clock_frame"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginStart="13dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layoutDirection="ltr"
            android:orientation="horizontal">

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/Neumatic"
                android:format12Hour="hh"
                android:format24Hour="HH"
                android:alpha="0.9"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:textColor="@android:color/system_accent1_400"
                android:textSize="100.0dp" />

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/Neumatic"
                android:format12Hour="mm"
                android:format24Hour="mm"
                android:alpha="0.9"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:textColor="@android:color/white"
                android:textSize="100.0dp" />
        </LinearLayout>
    </LinearLayout>

    <TextClock
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="21dp"
        android:fontFamily="@font/general_sans"
        android:includeFontPadding="false"
        android:format12Hour="EEEE, MMMM dd"
        android:format24Hour="EEEE, dd MMMM"
        android:singleLine="true"
        android:textAlignment="viewStart"
        android:textAllCaps="true"
        android:textColor="@android:color/white"
        android:textSize="8.0dp" />
</LinearLayout>
